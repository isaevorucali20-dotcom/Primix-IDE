rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Reusable, hardened global helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- Files collection rules ---
    match /files/{fileId} {
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn() 
        && isValidId(fileId) 
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.content is string
        && request.resource.data.content.size() <= 1048576 // 1MB limit
        && request.resource.data.name is string
        && request.resource.data.name.size() <= 256
        && request.resource.data.path is string
        && request.resource.data.path.size() <= 256
        && request.resource.data.platform is string
        && request.resource.data.platform.size() <= 64;

      allow update: if isSignedIn() 
        && isValidId(fileId)
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.path == resource.data.path // Immutability
        && request.resource.data.platform == resource.data.platform // Immutability
        && request.resource.data.content is string
        && request.resource.data.content.size() <= 1048576
        && request.resource.data.name is string
        && request.resource.data.name.size() <= 256;

      allow delete: if isSignedIn()
        && resource.data.userId == request.auth.uid;
    }

    // --- Chat collection rules ---
    match /chat/{messageId} {
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn()
        && isValidId(messageId)
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.role in ['user', 'model']
        && request.resource.data.text is string
        && request.resource.data.text.size() <= 524288
        && request.resource.data.timestamp is string
        && request.resource.data.timestamp.size() <= 64;

      allow delete: if isSignedIn()
        && resource.data.userId == request.auth.uid;
    }
  }
}
